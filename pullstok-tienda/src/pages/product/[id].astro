---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Nav from "@/components/Nav.astro";
import BadgeBar from "@/components/BadgeBar.astro";
import RelatedProducts from "@/components/RelatedProducts.astro";
import Footer from "@/components/Footer.astro";
import {
  resolveSlugFromHost,
  getStoreSettings,
  getStoreProducts,
  getStoreProductById,
  StoreNotAvailableError,
  StoreNotFoundError,
} from "@/lib/storeApi";

const { id } = Astro.params;
const slug = resolveSlugFromHost(Astro.request.headers.get("host"));

let settings;
let product;
let allProducts;
try {
  settings = await getStoreSettings(slug);
  product = await getStoreProductById(slug, id!);
  // Relacionados: mismos productos publicados de la org, sin el actual. No
  // hay endpoint dedicado de "relacionados" (no hay categorías/tags para
  // ese match todavía) — se reutiliza el catálogo completo y se filtra acá.
  allProducts = await getStoreProducts(slug);
} catch (error) {
  if (error instanceof StoreNotAvailableError) {
    return new Response("Tienda no disponible para este plan.", { status: 403 });
  }
  if (error instanceof StoreNotFoundError) {
    return new Response("Tienda no encontrada.", { status: 404 });
  }
  throw error;
}

if (!product) {
  return new Response("Producto no encontrado.", { status: 404 });
}

const relatedProducts = allProducts.filter((p) => p.id !== product!.id).slice(0, 4);

const outOfStock = product.quantity <= 0;
const priceFormatted = new Intl.NumberFormat("es-AR", {
  style: "currency",
  currency: "ARS",
  maximumFractionDigits: 0,
}).format(product.price);
---

<BaseLayout settings={settings} title={product.name}>
  <Nav settings={settings} />
  <main>
    <div class="mx-auto max-w-6xl px-6 py-16">
      <a href="/" class="text-sm text-muted-foreground hover:text-foreground">&larr; Volver al catálogo</a>

      <div class="mt-6 grid grid-cols-1 gap-12 md:grid-cols-2">
        <div class="overflow-hidden rounded-xl bg-muted">
          <div class="aspect-square w-full overflow-hidden">
            {
              product.image ? (
                <img src={product.image} alt={product.name} class="h-full w-full object-cover" />
              ) : (
                <div class="flex h-full w-full items-center justify-center text-muted-foreground">
                  Sin imagen
                </div>
              )
            }
          </div>
        </div>

        <div class="flex flex-col gap-4">
          <h1 class="text-3xl font-bold tracking-tight">{product.name}</h1>
          <p class="text-2xl font-semibold text-[var(--brand)]">{priceFormatted}</p>

          {product.description && <p class="text-muted-foreground">{product.description}</p>}

          {
            outOfStock ? (
              <span class="mt-2 inline-flex w-fit items-center rounded-full bg-muted px-3 py-1 text-xs font-semibold text-muted-foreground">
                Sin stock
              </span>
            ) : (
              <Fragment>
                <!-- Selector de cantidad: solo cambia el número en pantalla,
                     todavía no hay carrito real para multiplicar nada (ver
                     Add to Cart stub abajo — batch de carrito es posterior). -->
                <div class="mt-2 flex items-center gap-3">
                  <span class="text-sm font-medium text-foreground">Cantidad</span>
                  <div class="flex items-center rounded-md border border-border">
                    <button
                      type="button"
                      id="qty-decrement"
                      class="flex h-10 w-10 items-center justify-center text-lg text-foreground/70 transition hover:text-foreground"
                      aria-label="Restar cantidad"
                    >
                      &minus;
                    </button>
                    <span id="qty-value" class="w-10 text-center text-sm font-semibold" data-max={product.quantity}>1</span>
                    <button
                      type="button"
                      id="qty-increment"
                      class="flex h-10 w-10 items-center justify-center text-lg text-foreground/70 transition hover:text-foreground"
                      aria-label="Sumar cantidad"
                    >
                      &#43;
                    </button>
                  </div>
                </div>

                <div class="mt-2 flex flex-wrap gap-3">
                  <button
                    type="button"
                    id="add-to-cart-btn"
                    class="btn-brand w-fit"
                    data-product-id={product.id}
                    data-product-name={product.name}
                    data-product-price={product.price}
                    data-product-image={product.image ?? ""}
                    data-product-max={product.quantity}
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="h-4 w-4">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 1.872-3.876 2.617-6.16a.75.75 0 0 0-.65-.987l-13.45.022-.6-2.225M7.5 14.25 5.106 5.272M5.106 5.272 4.5 3" />
                    </svg>
                    Agregar al carrito
                  </button>
                  <a href="/cart" id="buy-now-link" class="btn-brand-outline w-fit">
                    Comprar ahora
                  </a>
                </div>
              </Fragment>
            )
          }
        </div>
      </div>
    </div>

    <BadgeBar badges={settings.badges} />
    <RelatedProducts products={relatedProducts} />
  </main>
  <Footer settings={settings} />
</BaseLayout>

<script>
  // Selector de cantidad + Agregar al carrito: el valor de `qty` vive en este
  // closure y es lo que se manda a addToCart() al click (respeta el +/- de
  // pantalla, no fuerza 1 como hace la card del catálogo).
  import { addToCart } from "@/lib/cart";

  const valueEl = document.getElementById("qty-value");
  const decrementBtn = document.getElementById("qty-decrement");
  const incrementBtn = document.getElementById("qty-increment");
  const addBtn = document.getElementById("add-to-cart-btn") as HTMLButtonElement | null;
  const buyNowLink = document.getElementById("buy-now-link") as HTMLAnchorElement | null;

  let qty = 1;

  if (valueEl && decrementBtn && incrementBtn) {
    const max = Number(valueEl.dataset.max ?? "1");

    const render = () => {
      valueEl.textContent = String(qty);
    };

    decrementBtn.addEventListener("click", () => {
      qty = Math.max(1, qty - 1);
      render();
    });

    incrementBtn.addEventListener("click", () => {
      qty = Math.min(max || 1, qty + 1);
      render();
    });
  }

  if (addBtn) {
    addBtn.addEventListener("click", () => {
      addToCart(
        {
          productId: addBtn.dataset.productId!,
          name: addBtn.dataset.productName!,
          price: Number(addBtn.dataset.productPrice),
          image: addBtn.dataset.productImage || null,
          maxQuantity: Number(addBtn.dataset.productMax),
        },
        qty,
      );
      addBtn.textContent = "¡Agregado!";
      setTimeout(() => {
        addBtn.textContent = "Agregar al carrito";
      }, 1200);
    });
  }

  // "Comprar ahora": agrega al carrito con la cantidad elegida y va directo
  // al carrito (no hay checkout de un solo producto separado — simplifica el
  // flujo, el carrito ya muestra "Finalizar compra").
  if (buyNowLink) {
    buyNowLink.addEventListener("click", () => {
      if (!addBtn) return;
      addToCart(
        {
          productId: addBtn.dataset.productId!,
          name: addBtn.dataset.productName!,
          price: Number(addBtn.dataset.productPrice),
          image: addBtn.dataset.productImage || null,
          maxQuantity: Number(addBtn.dataset.productMax),
        },
        qty,
      );
    });
  }
</script>
