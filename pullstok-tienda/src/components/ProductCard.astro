---
import type { StoreProduct } from "@/lib/storeApi";

interface Props {
  product: StoreProduct;
}

const { product } = Astro.props;
const outOfStock = product.quantity <= 0;

const priceFormatted = new Intl.NumberFormat("es-AR", {
  style: "currency",
  currency: "ARS",
  maximumFractionDigits: 0,
}).format(product.price);
---

<article class="group flex flex-col overflow-hidden rounded-xl border border-border bg-card transition duration-300 hover:-translate-y-1 hover:shadow-lg">
  <a href={`/product/${product.id}`} class="relative block overflow-hidden bg-muted">
    <div class="aspect-square w-full overflow-hidden">
      {
        product.image ? (
          <img
            src={product.image}
            alt={product.name}
            class="h-full w-full object-cover transition duration-300 group-hover:scale-105"
            loading="lazy"
          />
        ) : (
          <div class="flex h-full w-full items-center justify-center text-muted-foreground">
            Sin imagen
          </div>
        )
      }
    </div>

    <!-- Quick View: overlay que aparece on-hover, siempre lleva al detalle
         real (no hay modal de quick view en v1, el "quick" es la promesa
         visual estilo Bloom — el link es honesto, no finge nada). -->
    <span class="absolute inset-0 flex items-center justify-center bg-black/0 opacity-0 transition duration-300 group-hover:bg-black/10 group-hover:opacity-100">
      <span class="btn-brand shadow-md">Vista rápida</span>
    </span>
  </a>

  <div class="flex flex-1 flex-col gap-1 p-4">
    <a href={`/product/${product.id}`} class="font-medium text-foreground hover:underline">
      {product.name}
    </a>
    <p class="text-sm font-semibold text-[var(--brand)]">{priceFormatted}</p>

    {
      outOfStock ? (
        <span class="mt-3 inline-flex w-fit items-center rounded-full bg-muted px-3 py-1 text-xs font-semibold text-muted-foreground">
          Sin stock
        </span>
      ) : (
        <button
          type="button"
          class="btn-brand mt-3 w-full"
          disabled
          title="Carrito — próximamente"
        >
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" class="h-4 w-4">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 3h1.386c.51 0 .955.343 1.087.835l.383 1.437M7.5 14.25a3 3 0 0 0-3 3h15.75m-12.75-3h11.218c1.121-2.3 1.872-3.876 2.617-6.16a.75.75 0 0 0-.65-.987l-13.45.022-.6-2.225M7.5 14.25 5.106 5.272M5.106 5.272 4.5 3" />
          </svg>
          Agregar al carrito
        </button>
      )
    }
  </div>
</article>
