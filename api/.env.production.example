# === Plantilla de entorno de PRODUCCIÓN ===
# Copiá este archivo a `.env.production` (o `.env`) en el VPS y completá los valores REALES.
# NUNCA commitees el archivo con valores reales: solo este .example va al repo.

# Base de datos PostgreSQL
# Formato: postgresql://USUARIO:PASSWORD@HOST:PUERTO/BASE
DATABASE_URL="postgresql://nexo_user:CAMBIAME@localhost:5432/nexo"

# JWT — generá uno random fuerte con:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=CAMBIAME_POR_UNO_RANDOM_FUERTE

# Cloudflare R2 (imágenes de productos — almacenamiento S3-compatible)
# R2_ACCOUNT_ID: ID de cuenta de Cloudflare (dashboard R2 > "Account ID")
R2_ACCOUNT_ID=tu_account_id
# Credenciales del API Token de R2 (R2 > Manage R2 API Tokens)
R2_ACCESS_KEY_ID=tu_access_key_id
R2_SECRET_ACCESS_KEY=tu_secret_access_key
# Nombre del bucket creado en R2
R2_BUCKET_NAME=tu_bucket
# URL pública del bucket (dominio público de R2 o tu CDN), sin barra final
R2_PUBLIC_URL=https://tu-bucket-publico.r2.dev

# CORS — orígenes permitidos del frontend, separados por coma (sin espacios extra)
CORS_ORIGINS=https://tu-dominio.com,https://www.tu-dominio.com

# Servidor
PORT=5000
NODE_ENV=production
