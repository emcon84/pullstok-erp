// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Prisma 7: la conexión va en prisma.config.ts (migrate) y en el driver
  // adapter del PrismaClient (runtime). Ya no se declara `url` acá.
  provider = "postgresql"
}

enum Role {
  SUPERADMIN
  ADMIN
  EMPLOYEE
}

enum Industry {
  FERRETERIA
  KIOSCO
  INDUMENTARIA
  ALMACEN
  OTHER
}

enum Plan {
  BASICO
  PRO
  PREMIUM
}

// El tenant: cada negocio que compra el ERP es una Organization.
model Organization {
  id                    String      @id @default(uuid())
  name                  String
  slug                  String      @unique
  isActive              Boolean     @default(true)
  createdAt             DateTime    @default(now())
  address               String?
  phone                 String?
  taxId                 String?
  industry              Industry    @default(OTHER)
  onboardingCompletedAt DateTime?
  plan                  Plan        @default(BASICO)
  paidUntil             DateTime?
  taxCondition          String?
  users                 User[]
  products              Product[]
  categories            Category[]
  customers             Customer[]
  orders                Order[]
  quotations            Quotation[]
  sales                 Sale[]
  receipts              Receipt[]
  counters              Counter[]
  storeSettings         StoreSettings?
  invoices              Invoice[]

  @@map("organizations")
}

model User {
  id                 String        @id @default(uuid())
  email              String        @unique
  password           String
  role               Role          @default(EMPLOYEE)
  mustChangePassword Boolean       @default(true)
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  // null SOLO para el SUPERADMIN (la plataforma). Todo otro usuario pertenece a una org.
  organizationId     String?
  organization       Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("users")
}

model Customer {
  id             String       @id @default(uuid())
  name           String
  email          String
  phone          String?
  taxId          String?
  taxCondition   String?
  address        String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  orders         Order[]
  quotations     Quotation[]
  invoices       Invoice[]

  // Email único POR organización (dos negocios pueden tener el mismo cliente).
  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("customers")
}

model Category {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  products       Product[]

  @@unique([organizationId, name])
  @@map("categories")
}

model Product {
  id               String          @id @default(uuid())
  name             String
  price            Float
  description      String?
  categoryId       String?
  category         Category?       @relation(fields: [categoryId], references: [id])
  image            String?
  quantity         Int
  // Visibilidad en la tienda online pública (negocio.pullstok.com). Default
  // false: un producto nunca aparece publicado sin que el dueño lo decida.
  publishedToStore Boolean         @default(false)
  organizationId   String
  organization     Organization    @relation(fields: [organizationId], references: [id])
  orderItems       OrderItem[]
  quotationItems   QuotationItem[]
  saleItems        SaleItem[]

  @@index([organizationId])
  @@index([categoryId])
  @@map("products")
}

model Order {
  id             String       @id @default(uuid())
  customerId     String
  customer       Customer     @relation(fields: [customerId], references: [id])
  items          OrderItem[]
  totalAmount    Float
  status         OrderStatus  @default(PENDING)
  type           OrderType
  // Canal de origen: STORE (tienda online pública) vs INTERNAL (ERP). Default
  // INTERNAL para que las filas/flujos existentes no cambien de comportamiento.
  source         OrderSource  @default(INTERNAL)
  quotationId    String?
  quotation      Quotation?   @relation(fields: [quotationId], references: [id])
  receipt        String?
  createdAt      DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float

  @@map("order_items")
}

model Quotation {
  id             String          @id @default(uuid())
  customerId     String
  customer       Customer        @relation(fields: [customerId], references: [id])
  items          QuotationItem[]
  totalAmount    Float
  validUntil     DateTime
  createdAt      DateTime        @default(now())
  receipt        String?
  orders         Order[]
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("quotations")
}

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Int
  price       Float

  @@map("quotation_items")
}

model Sale {
  id             String       @id @default(uuid())
  items          SaleItem[]
  totalAmount    Float
  saleDate       DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  invoice        Invoice?

  @@index([organizationId])
  @@map("sales")
}

model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  quantity  Int
  category  String
  price     Float

  @@map("sale_items")
}

model Receipt {
  id              String       @id @default(uuid())
  type            String
  relatedDocument String
  receiptNumber   String
  createdAt       DateTime     @default(now())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("receipts")
}

// Numeración de comprobantes, ahora POR organización.
model Counter {
  id             String       @id @default(uuid())
  name           String
  sequenceValue  Int          @default(0)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name])
  @@map("counters")
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum OrderType {
  SALE
  PURCHASE
}

enum OrderSource {
  STORE
  INTERNAL
}

enum InvoiceStatus {
  DRAFT
  ISSUED
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
}

model Invoice {
  id              String        @id @default(uuid())
  organizationId  String
  organization    Organization  @relation(fields: [organizationId], references: [id])
  customerId      String
  customer        Customer      @relation(fields: [customerId], references: [id])
  number          String? // null en DRAFT; "FAC-0001" asignado solo al ISSUED
  issueDate       DateTime      @default(now())
  dueDate         DateTime?
  items           InvoiceItem[]
  subtotal        Float         @default(0)
  taxAmount       Float         @default(0)
  totalAmount     Float         @default(0)
  status          InvoiceStatus @default(DRAFT)
  paymentStatus   PaymentStatus @default(PENDING)
  notes           String?
  // --- Fase 2 (AFIP/ARCA WSFEv1), nullable, sin lógica ---
  tipoComprobante String?
  puntoVenta      Int?
  cae             String?
  caeVencimiento  DateTime?
  // --- Puente Sale→Invoice (opcional; facturas de servicio no tienen venta) ---
  saleId          String?       @unique
  sale            Sale?         @relation(fields: [saleId], references: [id])
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([organizationId, number])
  @@index([organizationId])
  @@map("invoices")
}

model InvoiceItem {
  id          String  @id @default(uuid())
  invoiceId   String
  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Float
  unitPrice   Float
  taxRate     Float   @default(21)
  lineTotal   Float // snapshot: quantity * unitPrice (sin IVA)

  @@map("invoice_items")
}

// Configuración de branding de la tienda online pública, 1:1 con Organization.
// A PROPÓSITO fuera de TENANT_MODELS (ver db.ts): es un modelo de fila única
// por org, se accede vía basePrisma filtrando por organizationId directamente
// (no necesita el scope automático de la extensión multi-tenant).
model StoreSettings {
  id             String       @id @default(uuid())
  organizationId String       @unique
  organization   Organization @relation(fields: [organizationId], references: [id])
  primaryColor   String       @default("#111827")
  logoUrl        String?
  bannerUrl      String?
  tagline        String?
  showNewsletter Boolean      @default(true)
  showBanner     Boolean      @default(true)
  // Badges configurables de confianza (envío gratis, garantía, etc.). Array
  // de hasta 3 objetos { title, subtitle } — NO hardcodeado, NO reviews/stars
  // (no tenemos backend para eso). El storefront solo muestra la barra si
  // este campo no es null/vacío.
  badges         Json?
  contactEmail   String?
  contactPhone   String?
  address        String?
  updatedAt      DateTime     @updatedAt

  @@map("store_settings")
}
