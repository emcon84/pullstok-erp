// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Prisma 7: la conexión va en prisma.config.ts (migrate) y en el driver
  // adapter del PrismaClient (runtime). Ya no se declara `url` acá.
  provider = "postgresql"
}

enum Role {
  SUPERADMIN
  ADMIN
  EMPLOYEE
}

enum Industry {
  FERRETERIA
  KIOSCO
  INDUMENTARIA
  ALMACEN
  OTHER
}

enum Plan {
  BASICO
  PRO
  PREMIUM
}

// El tenant: cada negocio que compra el ERP es una Organization.
model Organization {
  id                    String      @id @default(uuid())
  name                  String
  slug                  String      @unique
  isActive              Boolean     @default(true)
  createdAt             DateTime    @default(now())
  address               String?
  phone                 String?
  taxId                 String?
  industry              Industry    @default(OTHER)
  onboardingCompletedAt DateTime?
  plan                  Plan        @default(BASICO)
  paidUntil             DateTime?
  users                 User[]
  products              Product[]
  categories            Category[]
  customers             Customer[]
  orders                Order[]
  quotations            Quotation[]
  sales                 Sale[]
  receipts              Receipt[]
  counters              Counter[]

  @@map("organizations")
}

model User {
  id                 String        @id @default(uuid())
  email              String        @unique
  password           String
  role               Role          @default(EMPLOYEE)
  mustChangePassword Boolean       @default(true)
  isActive           Boolean       @default(true)
  createdAt          DateTime      @default(now())
  // null SOLO para el SUPERADMIN (la plataforma). Todo otro usuario pertenece a una org.
  organizationId     String?
  organization       Organization? @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("users")
}

model Customer {
  id             String       @id @default(uuid())
  name           String
  email          String
  phone          String?
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  orders         Order[]
  quotations     Quotation[]

  // Email único POR organización (dos negocios pueden tener el mismo cliente).
  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("customers")
}

model Category {
  id             String       @id @default(uuid())
  name           String
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  products       Product[]

  @@unique([organizationId, name])
  @@map("categories")
}

model Product {
  id             String          @id @default(uuid())
  name           String
  price          Float
  description    String?
  categoryId     String?
  category       Category?       @relation(fields: [categoryId], references: [id])
  image          String?
  quantity       Int
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])
  orderItems     OrderItem[]
  quotationItems QuotationItem[]
  saleItems      SaleItem[]

  @@index([organizationId])
  @@index([categoryId])
  @@map("products")
}

model Order {
  id             String       @id @default(uuid())
  customerId     String
  customer       Customer     @relation(fields: [customerId], references: [id])
  items          OrderItem[]
  totalAmount    Float
  status         OrderStatus  @default(PENDING)
  type           OrderType
  quotationId    String?
  quotation      Quotation?   @relation(fields: [quotationId], references: [id])
  receipt        String?
  createdAt      DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("orders")
}

model OrderItem {
  id        String  @id @default(uuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float

  @@map("order_items")
}

model Quotation {
  id             String          @id @default(uuid())
  customerId     String
  customer       Customer        @relation(fields: [customerId], references: [id])
  items          QuotationItem[]
  totalAmount    Float
  validUntil     DateTime
  createdAt      DateTime        @default(now())
  receipt        String?
  orders         Order[]
  organizationId String
  organization   Organization    @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("quotations")
}

model QuotationItem {
  id          String    @id @default(uuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId   String
  product     Product   @relation(fields: [productId], references: [id])
  quantity    Int
  price       Float

  @@map("quotation_items")
}

model Sale {
  id             String       @id @default(uuid())
  items          SaleItem[]
  totalAmount    Float
  saleDate       DateTime     @default(now())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("sales")
}

model SaleItem {
  id        String  @id @default(uuid())
  saleId    String
  sale      Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  quantity  Int
  category  String
  price     Float

  @@map("sale_items")
}

model Receipt {
  id              String       @id @default(uuid())
  type            String
  relatedDocument String
  receiptNumber   String
  createdAt       DateTime     @default(now())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@map("receipts")
}

// Numeración de comprobantes, ahora POR organización.
model Counter {
  id             String       @id @default(uuid())
  name           String
  sequenceValue  Int          @default(0)
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@unique([organizationId, name])
  @@map("counters")
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum OrderType {
  SALE
  PURCHASE
}
