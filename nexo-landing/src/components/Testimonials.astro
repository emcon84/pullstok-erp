---
// NOTA: testimonios placeholder. Reemplazar por casos reales de clientes
// antes de publicar la landing en producción.
const testimonials = [
  {
    name: "Marcela Suárez",
    business: "Almacén Doña Marce, Quilmes",
    quote:
      "Antes anotaba todo en un cuaderno y siempre terminaba contando mal el stock. Con Nexo sé exactamente qué tengo y qué se vendió en el día.",
  },
  {
    name: "Diego Ferreyra",
    business: "Ferretería El Tornillo, Córdoba",
    quote:
      "Lo que más me cambió fue dejar de comprar de más. Veo el stock real y pido justo lo que necesito.",
  },
  {
    name: "Lucía Paz",
    business: "Indumentaria Paz, Mendoza",
    quote:
      "Cargué todo el catálogo por CSV en una tarde. El onboarding te lleva de la mano, no me costó nada empezar.",
  },
];
---

<section class="px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        Comercios que ya dejaron el cuaderno
      </h2>
    </div>

    <!-- Testimonios placeholder — reemplazar por citas reales de clientes -->
    <div class="mt-12 grid gap-6 sm:grid-cols-3">
      {
        testimonials.map((t) => (
          <figure class="card gap-4">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="28"
              height="28"
              viewBox="0 0 24 24"
              fill="currentColor"
              class="text-primary/30"
              aria-hidden="true"
            >
              <path d="M9.983 3v7.391c0 5.704-3.731 9.57-8.983 10.609l-.995-2.151c2.432-.917 3.995-3.582 3.995-5.849h-4v-10h9.983zm14.017 0v7.391c0 5.704-3.748 9.571-9 10.609l-.996-2.151c2.433-.917 3.996-3.582 3.996-5.849h-3.983v-10h9.983z" />
            </svg>
            <blockquote class="text-sm text-foreground">
              "{t.quote}"
            </blockquote>
            <figcaption class="mt-auto">
              <p class="text-sm font-semibold text-foreground">{t.name}</p>
              <p class="text-xs text-muted-foreground">{t.business}</p>
            </figcaption>
          </figure>
        ))
      }
    </div>
  </div>
</section>
