---
// Isla mínima de interactividad: toggle mensual/anual.
// Sin framework — un bloque de script inline vanilla que vive en el cliente
// y se ejecuta al cargar la página (y re-engancha en astro:after-swap).
---

<div
  id="pricing-toggle"
  class="mx-auto flex w-fit items-center gap-3 rounded-full border border-border bg-card p-1.5 shadow-sm"
  data-billing="monthly"
>
  <button
    type="button"
    data-billing-option="monthly"
    class="rounded-full px-4 py-2 text-sm font-semibold transition-colors"
    aria-pressed="true"
  >
    Mensual
  </button>
  <button
    type="button"
    data-billing-option="annual"
    class="flex items-center gap-2 rounded-full px-4 py-2 text-sm font-semibold transition-colors"
    aria-pressed="false"
  >
    Anual
    <span class="badge bg-success/15 text-success">-20%</span>
  </button>
</div>

<script>
  function setupPricingToggle() {
    const root = document.getElementById("pricing-toggle");
    if (!root) return;

    const buttons = root.querySelectorAll<HTMLButtonElement>(
      "[data-billing-option]"
    );
    const priceNodes = document.querySelectorAll<HTMLElement>("[data-price]");
    const periodNodes = document.querySelectorAll<HTMLElement>(
      "[data-price-period]"
    );

    function applyBilling(billing: "monthly" | "annual") {
      root!.dataset.billing = billing;

      buttons.forEach((btn) => {
        const active = btn.dataset.billingOption === billing;
        btn.setAttribute("aria-pressed", String(active));
        btn.classList.toggle("bg-primary", active);
        btn.classList.toggle("text-primary-foreground", active);
        btn.classList.toggle("text-muted-foreground", !active);
      });

      priceNodes.forEach((node) => {
        const value =
          billing === "annual"
            ? node.dataset.priceAnnual
            : node.dataset.priceMonthly;
        if (value) node.textContent = value;
      });

      periodNodes.forEach((node) => {
        node.textContent = billing === "annual" ? "/año" : "/mes";
      });
    }

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const billing = btn.dataset.billingOption as "monthly" | "annual";
        applyBilling(billing);
      });
    });

    applyBilling("monthly");
  }

  setupPricingToggle();
  document.addEventListener("astro:after-swap", setupPricingToggle);
</script>
