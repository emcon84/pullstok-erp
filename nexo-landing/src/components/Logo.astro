---
// Isotipo de Nexo, calcado 1:1 de nexo-front/src/assets/logo.tsx (export LogoIcon)
// para mantener consistencia de marca entre la landing y la app.
interface Props {
  class?: string;
  showWordmark?: boolean;
}
const { class: className = "h-8 w-auto", showWordmark = true } = Astro.props;
---

<span class={`inline-flex items-center gap-2 ${className}`}>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 80 56"
    fill="none"
    class="h-full w-auto"
    aria-hidden="true"
  >
    <rect
      width="45.175"
      height="19.692"
      y="38.131"
      fill="#FF9D00"
      rx="9.846"
      transform="rotate(-43.495 0 38.13)"
    ></rect>
    <rect
      width="50.737"
      height="19.692"
      x="30.305"
      y="36.047"
      fill="#51CCEE"
      rx="9.846"
      transform="rotate(-45.273 30.305 36.047)"
    ></rect>
    <path
      fill="#F73C5C"
      d="M52.72 13.847c-7.688 7.8-14.059 14.261-14.059 14.261L24.602 42.37c-7.753-7.643-7.743-20.224.021-28.1 7.765-7.876 20.344-8.065 28.097-.422Z"
    ></path>
    <path
      fill="#2A8BEA"
      d="m24.38 42.15 14.058-14.261 14.06-14.261c7.753 7.643 7.743 20.224-.021 28.1-7.765 7.876-20.344 8.065-28.098.422Z"
    ></path>
  </svg>
  {
    showWordmark && (
      <span class="text-xl font-extrabold tracking-tight text-foreground">
        Nexo
      </span>
    )
  }
</span>
