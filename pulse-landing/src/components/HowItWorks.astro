---
const steps = [
  {
    number: "1",
    title: "Creá tu cuenta y cargá tu negocio",
    description:
      "Un wizard te guía paso a paso: nombre del negocio, rubro (ferretería, kiosco, indumentaria, almacén u otro) y categorías. Cinco minutos y listo.",
  },
  {
    number: "2",
    title: "Subí tus productos",
    description:
      "Cargalos a mano o importá un Excel/CSV con todo de una. Vos elegís lo que te resulte más rápido.",
  },
  {
    number: "3",
    title: "Empezá a vender y mirá los reportes",
    description:
      "Cada venta actualiza el stock solo. Y desde el dashboard ves qué se mueve, qué no, y cómo te va.",
  },
];
---

<section class="bg-muted/60 px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight text-foreground sm:text-4xl">
        Empezás a usarlo el mismo día
      </h2>
      <p class="mt-4 text-lg text-muted-foreground">
        Sin curso, sin manual de 50 páginas. Pulse te acompaña desde el primer
        click.
      </p>
    </div>

    <div class="relative mt-14 grid gap-10 sm:grid-cols-3 sm:gap-6">
      {
        steps.map((step, i) => (
          <div class="relative text-center sm:text-left">
            <div
              class="mx-auto flex h-12 w-12 items-center justify-center rounded-full bg-primary text-lg font-bold text-primary-foreground sm:mx-0"
              aria-hidden="true"
            >
              {step.number}
            </div>
            <h3 class="mt-4 text-lg font-semibold text-foreground">
              {step.title}
            </h3>
            <p class="mt-2 text-sm text-muted-foreground">
              {step.description}
            </p>
            {i < steps.length - 1 && (
              <div
                class="absolute top-6 left-[calc(50%+1.75rem)] hidden h-px w-[calc(100%-3.5rem)] border-t border-dashed border-border sm:block"
                aria-hidden="true"
              />
            )}
          </div>
        ))
      }
    </div>
  </div>
</section>
