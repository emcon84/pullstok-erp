{
  "name": "nexo-erp",
  "private": true,
  "version": "1.0.0",
  "description": "Nexo ERP - sistema de stock multi-tenant",
  "scripts": {
    "dev:api": "pnpm --filter ./api dev",
    "dev:front": "pnpm --filter ./nexo-front dev",
    "dev:landing": "pnpm --filter ./nexo-landing dev",
    "build": "pnpm -r build"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild"
    ]
  }
}
