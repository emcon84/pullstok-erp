---
const DEMO_URL = "https://app.pullstok.com/?demo=1";
---

<section class="relative overflow-hidden px-4 pt-10 pb-16 sm:px-6 sm:pt-16 sm:pb-24 lg:px-8">
  <!-- Blobs de color de marca, flotando de fondo -->
  <div class="pointer-events-none absolute inset-0 -z-10" aria-hidden="true">
    <div class="blob -left-24 top-10 h-72 w-72 opacity-25" style="background: var(--brand-orange);"></div>
    <div class="blob right-[-6rem] top-40 h-80 w-80 opacity-20" style="background: var(--brand-cyan); animation-delay: -4s;"></div>
    <div class="blob bottom-0 left-1/3 h-64 w-64 opacity-[0.12]" style="background: var(--brand-red); animation-delay: -8s;"></div>
  </div>

  <div class="mx-auto grid max-w-7xl items-center gap-12 lg:grid-cols-[1.05fr_1fr] lg:gap-10">
    <!-- Columna texto -->
    <div class="text-center lg:text-left">
      <span class="badge mb-6 border-[1.5px] border-border bg-card text-foreground">
        <span class="text-base leading-none">🧉</span>
        Hecho en Argentina, para comercios de barrio
      </span>

      <h1 class="text-[2.7rem] font-extrabold leading-[1.02] text-foreground sm:text-6xl lg:text-[4.25rem]">
        Del cuaderno<br />
        al <span class="underline-hand text-primary">control total</span>
        <span class="inline-block animate-wiggle align-middle text-brand-orange">
          <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="inline h-9 w-9 sm:h-11 sm:w-11"><path d="M12 2l2.2 6.6L21 9l-5.4 4 2 6.8L12 16l-5.6 3.8 2-6.8L3 9l6.8-.4z"/></svg>
        </span>
      </h1>

      <p class="mx-auto mt-6 max-w-xl text-lg text-muted-foreground sm:text-xl lg:mx-0">
        Pullstok es el sistema de gestión para kioscos, almacenes, ferreterías e
        indumentaria. Controlá stock, vendé y mirá tus números reales — y si querés,
        abrí tu <strong class="font-bold text-foreground">tienda online</strong> en un clic.
      </p>

      <div class="mt-9 flex flex-col items-center gap-3 sm:flex-row lg:items-start lg:justify-start">
        <a href={DEMO_URL} class="btn btn-accent w-full sm:w-auto">
          Probá el demo gratis
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
        </a>
        <a href="#caracteristicas" class="btn btn-outline w-full sm:w-auto">
          Ver cómo funciona
        </a>
      </div>

      <div class="mt-6 flex items-center justify-center gap-2 text-sm font-medium text-muted-foreground lg:justify-start">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-success"><path d="M20 6 9 17l-5-5"/></svg>
        Sin tarjeta de crédito · Empezás en 2 minutos
      </div>
    </div>

    <!-- Columna visual: foto humana + tarjetas de producto (sticker) -->
    <div class="relative mx-auto w-full max-w-md lg:mx-0 lg:max-w-none">
      <!-- Foto real de un comerciante (stock Pexels, libre de uso comercial) -->
      <div class="card-pop relative aspect-[4/5] overflow-hidden rounded-[2rem] p-0">
        <img
          src="/images/comerciante.jpg"
          alt="Comerciante sonriendo en su negocio, rodeado de sus productos"
          width="1000"
          height="1250"
          fetchpriority="high"
          class="h-full w-full object-cover"
        />
      </div>

      <!-- Tarjeta flotante: ventas de hoy -->
      <div class="card card-pop absolute -left-4 top-10 w-44 gap-1 p-4 animate-float sm:-left-8">
        <p class="text-xs font-semibold text-muted-foreground">Ventas de hoy</p>
        <p class="font-display text-2xl font-extrabold text-foreground">$184.350</p>
        <p class="flex items-center gap-1 text-xs font-bold text-success">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg>
          +12% vs. ayer
        </p>
      </div>

      <!-- Tarjeta flotante: stock crítico -->
      <div class="card card-pop absolute -bottom-5 -right-3 w-48 gap-1 p-4 animate-float-slow sm:-right-6">
        <p class="text-xs font-semibold text-muted-foreground">Stock crítico</p>
        <p class="font-display text-2xl font-extrabold text-foreground">7 ítems</p>
        <div class="mt-1 h-2 w-full overflow-hidden rounded-full bg-muted">
          <div class="h-full w-2/3 rounded-full" style="background: var(--brand-orange);"></div>
        </div>
      </div>

      <!-- Pin "tienda online activa" -->
      <div class="badge absolute -top-3 right-6 rotate-2 bg-brand-cyan text-foreground shadow-[0_10px_24px_-12px_rgba(81,204,238,0.9)]">
        🛒 Tienda online activa
      </div>
    </div>
  </div>
</section>
