---
import PricingToggle from "@/components/PricingToggle.astro";
import { WEB3FORMS_KEY } from "@/consts";

const rubros = [
  "Kiosco",
  "Almacén / Minimercado",
  "Ferretería",
  "Indumentaria",
  "Gastronomía",
  "Otro",
];

const plans = [
  {
    name: "Básico",
    tagline: "Para el kiosco o almacén que arranca",
    monthly: "$35.000",
    annual: "$336.000",
    featured: false,
    features: [
      "2 usuarios",
      "Hasta 500 productos",
      "Control de stock",
      "Ventas y clientes",
      "Sin tienda online",
    ],
  },
  {
    name: "Pro",
    tagline: "Para el negocio que crece y vende online",
    monthly: "$70.000",
    annual: "$672.000",
    featured: true,
    features: [
      "10 usuarios",
      "Productos ilimitados",
      "Todo lo del Básico",
      "Tienda online (hasta 100 productos)",
      "Presupuestos, pedidos y remitos",
      "Reportes y dashboard",
    ],
  },
  {
    name: "Premium",
    tagline: "Para la cadena que necesita todo",
    monthly: "$130.000",
    annual: "$1.248.000",
    featured: false,
    features: [
      "Usuarios ilimitados",
      "Productos ilimitados",
      "Todo lo del Pro",
      "Tienda online ilimitada",
      "Soporte prioritario",
      "Multi-sucursal (próximamente)",
    ],
  },
];
---

<section id="precios" class="px-4 py-20 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-7xl">
    <div class="mx-auto max-w-2xl text-center">
      <span class="badge bg-brand-orange-soft text-[#b86e00]">💸 Precios claros</span>
      <h2 class="mt-4 text-4xl font-extrabold tracking-tight text-foreground sm:text-5xl">
        Un plan para cada etapa de tu negocio
      </h2>
      <p class="mt-4 text-lg text-muted-foreground">
        Sin letra chica. Empezás gratis y elegís el plan cuando estés listo.
      </p>
    </div>

    <div class="mt-8 flex justify-center">
      <PricingToggle />
    </div>

    <div class="mt-12 grid gap-6 lg:grid-cols-3">
      {
        plans.map((plan) => (
          <div
            class={`card relative gap-6 ${
              plan.featured
                ? "border-2 border-brand-blue bg-accent/40 shadow-[0_24px_50px_-24px_rgba(42,139,234,0.55)] lg:-translate-y-3"
                : ""
            }`}
          >
            {plan.featured && (
              <span class="badge absolute -top-3 left-1/2 -translate-x-1/2 bg-brand-orange text-[#3b2a00] shadow-[0_8px_18px_-8px_rgba(255,157,0,0.9)]">
                ⭐ Más popular
              </span>
            )}

            <div>
              <h3 class="text-lg font-semibold text-foreground">{plan.name}</h3>
              <p class="mt-1 text-sm text-muted-foreground">{plan.tagline}</p>
            </div>

            <div class="flex items-baseline gap-1">
              <span
                class="font-display text-5xl font-extrabold tracking-tight text-foreground"
                data-price
                data-price-monthly={plan.monthly}
                data-price-annual={plan.annual}
              >
                {plan.monthly}
              </span>
              <span class="text-sm font-medium text-muted-foreground" data-price-period>
                /mes
              </span>
            </div>

            <ul class="flex flex-col gap-2.5">
              {plan.features.map((feature) => (
                <li class="flex items-start gap-2 text-sm text-foreground">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="18"
                    height="18"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2.5"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="mt-0.5 shrink-0 text-success"
                    aria-hidden="true"
                  >
                    <path d="M20 6 9 17l-5-5" />
                  </svg>
                  <span>{feature}</span>
                </li>
              ))}
            </ul>

            <button
              type="button"
              data-plan-cta
              data-plan={plan.name}
              class={`btn mt-auto w-full ${
                plan.featured ? "btn-primary" : "btn-outline"
              }`}
            >
              Empezar
            </button>
          </div>
        ))
      }
    </div>

    <p class="mt-8 text-center text-sm text-muted-foreground">
      * Precios en pesos argentinos, IVA incluido.
    </p>
  </div>

  <!-- Modal de pedido (se abre al tocar "Empezar") -->
  <dialog id="lead-modal" class="lead-modal w-[92vw] max-w-lg rounded-3xl border-[1.5px] border-border bg-card p-0 text-foreground shadow-2xl backdrop:bg-foreground/40 backdrop:backdrop-blur-sm">
    <!-- Estado: formulario -->
    <form id="lead-form" class="flex flex-col gap-4 p-6 sm:p-8">
      <div class="flex items-start justify-between gap-4">
        <div>
          <h3 class="text-2xl font-extrabold tracking-tight">Empezá con Pullstok</h3>
          <p class="mt-1 text-sm text-muted-foreground">
            Dejanos tus datos y te contactamos para activar tu cuenta.
          </p>
        </div>
        <button type="button" data-close aria-label="Cerrar" class="shrink-0 rounded-full p-1.5 text-muted-foreground hover:bg-secondary hover:text-foreground">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18M6 6l12 12"/></svg>
        </button>
      </div>

      <span class="badge w-fit bg-brand-blue-soft text-brand-blue" id="lead-plan-chip">Plan</span>

      <!-- Campos ocultos para Web3Forms -->
      <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
      <input type="hidden" name="subject" value="Nuevo pedido de plan — Pullstok" />
      <input type="hidden" name="from_name" value="Landing Pullstok" />
      <input type="hidden" name="plan" value="" />
      <!-- Honeypot anti-spam (debe quedar vacío) -->
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

      <div class="grid gap-4 sm:grid-cols-2">
        <label class="flex flex-col gap-1.5 text-sm font-semibold">
          Nombre y apellido
          <input name="nombre" required type="text" autocomplete="name" class="lead-input" placeholder="Juan Pérez" />
        </label>
        <label class="flex flex-col gap-1.5 text-sm font-semibold">
          Nombre del negocio
          <input name="negocio" required type="text" class="lead-input" placeholder="Almacén Don Juan" />
        </label>
        <label class="flex flex-col gap-1.5 text-sm font-semibold">
          Email
          <input name="email" required type="email" autocomplete="email" class="lead-input" placeholder="vos@negocio.com" />
        </label>
        <label class="flex flex-col gap-1.5 text-sm font-semibold">
          WhatsApp
          <input name="whatsapp" required type="tel" autocomplete="tel" class="lead-input" placeholder="+54 9 11 ..." />
        </label>
      </div>

      <label class="flex flex-col gap-1.5 text-sm font-semibold">
        Rubro
        <select name="rubro" required class="lead-input">
          <option value="" disabled selected>Elegí tu rubro</option>
          {rubros.map((r) => <option value={r}>{r}</option>)}
        </select>
      </label>

      <label class="flex flex-col gap-1.5 text-sm font-semibold">
        Mensaje <span class="font-normal text-muted-foreground">(opcional)</span>
        <textarea name="mensaje" rows="2" class="lead-input resize-none" placeholder="Contanos algo de tu negocio..."></textarea>
      </label>

      <p id="lead-error" class="hidden text-sm font-medium text-destructive"></p>

      <button type="submit" class="btn btn-accent mt-1 w-full">Enviar pedido</button>
      <p class="text-center text-xs text-muted-foreground">No es un pago. Te contactamos para activar tu plan.</p>
    </form>

    <!-- Estado: éxito -->
    <div id="lead-success" hidden class="flex flex-col items-center gap-3 p-8 text-center">
      <span class="flex h-16 w-16 items-center justify-center rounded-full bg-success/15 text-success">
        <svg width="34" height="34" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
      </span>
      <h3 class="text-2xl font-extrabold tracking-tight">¡Pedido enviado! 🎉</h3>
      <p class="max-w-xs text-muted-foreground">Te vamos a contactar a la brevedad para activar tu cuenta. ¡Gracias por elegir Pullstok!</p>
      <button type="button" data-close class="btn btn-outline mt-2">Cerrar</button>
    </div>
  </dialog>
</section>

<style>
  .lead-modal {
    position: fixed;
    inset: 0;
    margin: auto;
    max-height: 92vh;
  }
  .lead-modal[open] {
    animation: lead-pop 180ms ease;
  }
  @keyframes lead-pop {
    from { transform: translateY(12px) scale(0.98); opacity: 0; }
    to { transform: translateY(0) scale(1); opacity: 1; }
  }
</style>

<script>
  function setupLeadModal() {
    const modal = document.getElementById("lead-modal") as HTMLDialogElement | null;
    const form = document.getElementById("lead-form") as HTMLFormElement | null;
    if (!modal || !form) return;

    const planField = form.querySelector<HTMLInputElement>('[name="plan"]')!;
    const planChip = document.getElementById("lead-plan-chip")!;
    const errorEl = document.getElementById("lead-error")!;
    const successEl = document.getElementById("lead-success") as HTMLElement;
    const submitBtn = form.querySelector<HTMLButtonElement>('[type="submit"]')!;

    document.querySelectorAll<HTMLButtonElement>("[data-plan-cta]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const plan = btn.dataset.plan ?? "";
        planField.value = plan;
        planChip.textContent = "Plan " + plan;
        // reset estados
        form.hidden = false;
        successEl.hidden = true;
        errorEl.classList.add("hidden");
        form.reset();
        planField.value = plan;
        modal.showModal();
      });
    });

    modal.querySelectorAll("[data-close]").forEach((b) =>
      b.addEventListener("click", () => modal.close())
    );
    // Cerrar al clickear el backdrop
    modal.addEventListener("click", (e) => {
      if (e.target === modal) modal.close();
    });

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorEl.classList.add("hidden");
      submitBtn.disabled = true;
      submitBtn.textContent = "Enviando...";
      try {
        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: { Accept: "application/json" },
          body: new FormData(form),
        });
        const data = await res.json();
        if (data.success) {
          form.hidden = true;
          successEl.hidden = false;
        } else {
          throw new Error(data.message || "Error");
        }
      } catch (err) {
        errorEl.textContent =
          "No pudimos enviar el pedido. Probá de nuevo o escribinos por WhatsApp.";
        errorEl.classList.remove("hidden");
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = "Enviar pedido";
      }
    });
  }

  setupLeadModal();
  document.addEventListener("astro:after-swap", setupLeadModal);
</script>
